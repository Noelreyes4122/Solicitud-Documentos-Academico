# PostgreSQL (Neon) — obtén estas URLs en neon.tech
DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require"
DIRECT_URL="postgresql://user:password@host/dbname?sslmode=require"

# NextAuth — genera uno aleatorio: openssl rand -base64 32
AUTH_SECRET="tu-secreto-muy-seguro-aqui"
NEXTAUTH_SECRET="tu-secreto-muy-seguro-aqui"

# URL de tu app (en Vercel será tu dominio)
NEXTAUTH_URL="https://tu-app.vercel.app"
